# ────────────────────────────────────────────────────────────
#  AI Interview Prep — Environment Variables
# ────────────────────────────────────────────────────────────
#  Copy this file to .env and fill in your values.
#  NEVER commit .env to version control!
# ────────────────────────────────────────────────────────────

# ── Option A: Direct Anthropic API (dev only) ───────────────
# Your Anthropic API key from https://console.anthropic.com
# WARNING: This exposes your key in the browser bundle.
# Only use for local development — remove before deploying!
VITE_ANTHROPIC_API_KEY=sk-ant-your-key-here

# ── Option B: Backend Proxy (recommended for production) ────
# Point this to your Express/FastAPI backend's /api/chat route
# When set, this overrides the direct API call above.
# VITE_API_URL=http://localhost:3001/api/chat
